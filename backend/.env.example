# DailyDate Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dailydate?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_random

# Email (Gmail SMTP)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# ImageKit (for image uploads)
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id

# Redis (for Socket.IO adapter and BullMQ)
REDIS_URL=redis://localhost:6379
# Or for Redis Cloud:
# REDIS_URL=redis://default:password@redis-host.com:6379

# Razorpay (for payments)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Firebase Admin (for push notifications)
# Download service account JSON from Firebase Console > Project Settings > Service Accounts
# Save as config/dailydate-firebase-adminsdk.json
# Or set as base64 encoded string:
FIREBASE_SERVICE_ACCOUNT_BASE64=your_base64_encoded_service_account_json

# FCM Server Key (legacy, optional if using Firebase Admin)
FCM_SERVER_KEY=your_fcm_server_key

# Google OAuth (optional, for Google Sign-In)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Bot System Configuration
# Set to "true" to enable bot engagement system
ENABLE_BOT_SYSTEM=true
# Cron schedule for bot online status updates (default: every 30 minutes)
BOT_ONLINE_CRON=*/30 * * * *

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS (comma-separated allowed origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://192.168.1.65:5000
